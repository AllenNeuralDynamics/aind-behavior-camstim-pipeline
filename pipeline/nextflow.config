process {
    maxForks = 50
    queueSize = 50
}

process.resourceLabels = ['allen-batch-pipeline': 'aind-behavior-camstim-pipeline']

env {
    PIPELINE_NAME = "aind-behavior-camstim-pipeline"
    PIPELINE_VERSION = "0.2.3"
    PIPELINE_URL = "https://github.com/AllenNeuralDynamics/aind-behavior-camstim-pipeline"
}
